# --- Bắt buộc trên Vercel ---
# Chuỗi ngẫu nhiên >= 32 ký tự (cookie session)
SESSION_SECRET=your-random-secret-at-least-32-characters

# Turso (SQLite cloud) — tạo free tại https://turso.tech
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Vercel Blob — bật Storage > Blob trên Vercel dashboard
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# --- Local dev (tuỳ chọn) ---
# Không set TURSO_* → dùng file data/hub.db tự động
# Không set BLOB_* → lưu upload vào data/uploads/
